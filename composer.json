{
    "name": "collei/psharp-skeleton",
    "description": "Another PHP microframework for webapps",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.0",
        "collei/psharp": "^0.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "App"
        }
    },
    "authors": [
        {
            "name": "Al Ju",
            "email": "alarido.su@gmail.com"
        }
    ],
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('appsettings.json') || copy('appsettings.json-example', 'appsettings.json');\"",
            "npm install --ignore-scripts",
            "npm run build"
        ],
        "dev": [
            ""
        ],
        "test": [
            ""
        ],
        "post-autoload-dump": [
            ""
        ],
        "post-update-cmd": [
            ""
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('appsettings.json') || copy('appsettings.json-example', 'appsettings.json');\""
        ],
        "post-create-project-cmd": [
            ""
        ],
        "pre-package-uninstall": [
            ""
        ]
    },
    "extra": {
        "psharp": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}